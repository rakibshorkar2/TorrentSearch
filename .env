# TorrentFlow Environment Configuration
# Copy this file to .env and fill in your values

# App Configuration
APP_NAME=TorrentFlow
APP_VERSION=1.0.0

# API Endpoints (defaults point to public proxies)
TPB_API_URL=https://apibay.org
EZTV_URL=https://eztv.re
NYAA_SI_URL=https://nyaa.si
YTS_API_URL=https://yts.mx/api/v2
1337X_URL=https://1337x.to
SEEDR_API_URL=https://www.seedr.cc/api

# Connection Settings
CONNECT_TIMEOUT=10000
RECEIVE_TIMEOUT=30000
MAX_RETRIES=3
